# Configuration de l'application web (copier vers .env, jamais commité)

# PostgreSQL en production (URL interne Coolify) ; SQLite en dev local.
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql+psycopg://utilisateur:motdepasse@hote:5432/classement

# Clé de signature des sessions — générer : python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=a-remplacer

# Stockage des justificatifs PDF (volume persistant Coolify : /data/uploads)
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# Cookies "secure" derrière HTTPS (proxy Coolify) : mettre 1 en production
COOKIE_SECURE=0

# Campagne initiale (consommée par webapp.scripts.seed)
CAMPAIGN_GRID_ID=u3-residences-scientifiques
CAMPAIGN_INSTITUTION_ID=enset-skikda
CAMPAIGN_DATE=2026-06-30
CAMPAIGN_WINDOW_REFERENCE=cloture
